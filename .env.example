# Optional: a single bearer token that the HTTP server will also accept
# alongside tokens created via `sharedbrain token create`.
# Useful for quick local testing. For production, prefer `sharedbrain token create`.
# SHAREDBRAIN_TOKEN=sb_replace_me

# Optional: the publicly-reachable URL for your HTTP MCP server (used in OAuth metadata).
# SHAREDBRAIN_PUBLIC_URL=https://brain.example.com
